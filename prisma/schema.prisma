generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  role          UserRole  @default(USER)
  linkLimit     Int       @default(10) // Link creation limit for regular users
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts      Account[]
  sessions      Session[]
  links         Link[]
  customRequests CustomLinkRequest[]
  allowedDomains DomainAllowedUser[]
  adminLogs     AdminLog[]

  @@map("users")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verificationtokens")
}

model Domain {
  id           String            @id @default(cuid())
  domain       String            @unique // e.g., "tiny.mwit.link", "s.mwit.link"
  isActive     Boolean           @default(true)
  restriction  DomainRestriction @default(EVERYONE) // Who can use this domain
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  links Link[]
  allowedUsers DomainAllowedUser[]

  @@map("domains")
}

model DomainAllowedUser {
  id       String @id @default(cuid())
  domainId String
  userId   String
  
  domain Domain @relation(fields: [domainId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([domainId, userId])
  @@map("domain_allowed_users")
}

model Link {
  id          String     @id @default(cuid())
  shortCode   String     // The short identifier (e.g., "abc123")
  originalUrl String     @db.Text
  title       String?    // Optional title for the link
  description String?    // Optional description
  domainId    String
  userId      String
  isActive    Boolean    @default(true)
  isCustom    Boolean    @default(false) // Whether this was a custom shortcode
  clicks      Int        @default(0)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  expiresAt   DateTime?  // Optional expiration date

  domain Domain @relation(fields: [domainId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  analytics LinkAnalytics[]
  abuseReports AbuseReport[]

  @@unique([shortCode, domainId]) // Ensure unique shortcodes per domain
  @@map("links")
}

model CustomLinkRequest {
  id          String                @id @default(cuid())
  shortCode   String                // Requested custom shortcode
  originalUrl String                @db.Text
  title       String?
  description String?
  domainId    String
  userId      String
  status      CustomRequestStatus   @default(PENDING)
  adminNote   String?               // Admin's note when approving/rejecting
  reviewedBy  String?               // Admin who reviewed the request
  reviewedAt  DateTime?
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("custom_link_requests")
}

model LinkAnalytics {
  id          String   @id @default(cuid())
  linkId      String
  ipAddress   String?  // Not used for privacy reasons
  userAgent   String?
  referer     String?
  country     String?
  city        String?
  device      String?  // Mobile, Desktop, Tablet
  browser     String?  // Chrome, Firefox, Safari, etc.
  os          String?  // Windows, macOS, Linux, iOS, Android
  language    String?  // Browser language
  utm_source  String?  // UTM tracking parameters
  utm_medium  String?
  utm_campaign String?
  utm_term    String?
  utm_content String?
  clickedAt   DateTime @default(now())

  link Link @relation(fields: [linkId], references: [id], onDelete: Cascade)

  @@index([linkId])
  @@index([clickedAt])
  @@map("link_analytics")
}

model AdminLog {
  id          String      @id @default(cuid())
  adminId     String      // Admin who performed the action
  action      AdminAction
  entityType  String      // 'user', 'link', 'domain', 'custom_request', 'abuse_report'
  entityId    String?     // ID of the affected entity
  details     Json?       // Additional details about the action
  ipAddress   String?     // Admin's IP address
  userAgent   String?     // Admin's user agent
  createdAt   DateTime    @default(now())

  admin User @relation(fields: [adminId], references: [id], onDelete: Cascade)

  @@index([adminId])
  @@index([action])
  @@index([entityType])
  @@index([createdAt])
  @@map("admin_logs")
}

enum UserRole {
  USER         // Can create limited links, needs approval for custom URLs
  SPECIAL_USER // Can create unlimited links and custom URLs without approval
  ADMIN        // Full system access, can moderate and manage
}

enum CustomRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

enum DomainRestriction {
  EVERYONE     // Anyone can use this domain
  ADMIN_ONLY   // Only admins can use this domain
  SPECIFIC_USERS // Only specific users can use this domain
}

model AbuseReport {
  id          String            @id @default(cuid())
  linkId      String
  reporterIp  String?           // Not used for privacy reasons
  reporterEmail String?         // Optional email for follow-up
  reportType  AbuseReportType
  description String?           @db.Text // Additional details from reporter
  status      AbuseReportStatus @default(PENDING)
  reviewedBy  String?           // Admin who reviewed the report
  reviewedAt  DateTime?
  adminNote   String?           @db.Text // Admin's note when reviewing
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  link Link @relation(fields: [linkId], references: [id], onDelete: Cascade)

  @@map("abuse_reports")
}

enum AbuseReportType {
  SPAM         // Spam or unwanted content
  MALWARE      // Malicious software or phishing
  ILLEGAL      // Illegal content
  COPYRIGHT    // Copyright infringement
  HARASSMENT   // Harassment or abuse
  ADULT_CONTENT // Adult/inappropriate content
  SCAM         // Scam or fraud
  OTHER        // Other type of abuse
}

enum AbuseReportStatus {
  PENDING      // Report submitted, awaiting review
  INVESTIGATING // Report is being investigated
  RESOLVED     // Report resolved, action taken
  DISMISSED    // Report dismissed as invalid
}

enum AdminAction {
  USER_ROLE_CHANGED     // Admin changed user's role
  USER_LIMIT_CHANGED    // Admin changed user's link limit
  USER_BANNED           // Admin banned a user
  USER_UNBANNED         // Admin unbanned a user
  LINK_DELETED          // Admin deleted a link
  LINK_DEACTIVATED      // Admin deactivated a link
  LINK_REACTIVATED      // Admin reactivated a link
  CUSTOM_REQUEST_APPROVED // Admin approved custom link request
  CUSTOM_REQUEST_REJECTED // Admin rejected custom link request
  DOMAIN_CREATED        // Admin created new domain
  DOMAIN_UPDATED        // Admin updated domain settings
  DOMAIN_DELETED        // Admin deleted domain
  ABUSE_REPORT_REVIEWED // Admin reviewed abuse report
  SYSTEM_SETTINGS_CHANGED // Admin changed system settings
  BULK_ACTION_PERFORMED // Admin performed bulk action
}
